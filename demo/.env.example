# Email configuration for AutoDrive

# Email address that receives feedback and appointment requests (the company email)
COMPANY_EMAIL=company@example.com

# Email service provider (gmail, outlook, yahoo, etc.)
EMAIL_SERVICE=gmail

# Password / app password for the above email account.
# For Gmail use an "App Password" (not your normal password).
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your_app_password_here

PORT=3000
